<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:title" content="{{ ogTitle or title }}">
  <meta property="og:description" content="{{ ogDescription or description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/assets/images/og-image.jpg">
  <meta name="twitter:card" content="summary_large_image">

  <link rel="icon" href="{{ root }}assets/icons/favicon-32.png" sizes="32x32" type="image/png">
  <meta name="theme-color" content="#6B6F4E">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Playfair+Display:wght@500;600;700&display=swap" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Playfair+Display:wght@500;600;700&display=swap"></noscript>
  <!-- CSS crítico inline (above-the-fold): subconjunto de assets/css/styles.css para
       renderização imediata. A folha completa (fonte da verdade) carrega logo abaixo, de
       forma assíncrona. Se editar tokens/header/hero no styles.css, reflita aqui também. -->
  <style>
    :root{--cor-creme:#F6F3EF;--cor-bege:#E7DFCF;--cor-oliva:#6B6F4E;--cor-salvia:#A7AD8A;--cor-marrom:#3A352F;--cor-cinza:#D9D6CF;--oliva-escuro:#545839;--marrom-suave:#575049;--fonte-titulo:"Playfair Display",Georgia,"Times New Roman",serif;--fonte-corpo:"Lato",system-ui,-apple-system,Segoe UI,Roboto,sans-serif;--fs-xs:clamp(0.78rem,0.74rem + 0.2vw,0.86rem);--fs-sm:clamp(0.88rem,0.84rem + 0.25vw,0.95rem);--fs-base:clamp(1rem,0.96rem + 0.3vw,1.12rem);--fs-md:clamp(1.15rem,1.05rem + 0.5vw,1.35rem);--fs-lg:clamp(1.4rem,1.2rem + 1vw,1.9rem);--fs-xl:clamp(1.9rem,1.5rem + 2vw,2.8rem);--fs-hero:clamp(2.1rem,1.4rem + 3.4vw,3.8rem);--gap:clamp(1rem,0.6rem + 1.6vw,2rem);--container:1140px;--container-texto:70ch;--raio:14px;--raio-sm:8px;--sombra:0 10px 30px -18px rgba(61,53,45,0.45);--borda:1px solid var(--cor-cinza);--transicao:220ms ease}
    *,*::before,*::after{box-sizing:border-box}*{margin:0}
    html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
    body{font-family:var(--fonte-corpo);font-size:var(--fs-base);line-height:1.65;color:var(--cor-marrom);background:var(--cor-creme);-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
    img,picture,svg{display:block;max-width:100%}img{height:auto}
    a{color:inherit;transition:color var(--transicao)}a:hover{color:var(--cor-oliva)}
    ul[class]{list-style:none;padding:0}button{font:inherit;color:inherit;cursor:pointer}
    h1,h2,h3,h4{font-family:var(--fonte-titulo);font-weight:600;line-height:1.18;color:var(--cor-marrom);text-wrap:balance}
    h1{font-size:var(--fs-xl)}h2{font-size:var(--fs-lg)}h3{font-size:var(--fs-md)}p{max-width:var(--container-texto)}
    :focus-visible{outline:3px solid var(--cor-oliva);outline-offset:3px;border-radius:3px}
    .container{width:min(100% - 2.5rem,var(--container));margin-inline:auto}
    .apoio{font-size:var(--fs-md);color:var(--marrom-suave)}
    .visually-hidden{position:absolute!important;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0}
    .skip-link{position:absolute;left:1rem;top:-3rem;background:var(--cor-oliva);color:var(--cor-creme);padding:0.6rem 1rem;border-radius:var(--raio-sm);z-index:1000;transition:top var(--transicao)}
    .skip-link:focus{top:1rem;color:var(--cor-creme)}
    .cabecalho{position:sticky;top:0;z-index:100;background:rgba(246,242,235,0.78);backdrop-filter:saturate(180%) blur(10px);-webkit-backdrop-filter:saturate(180%) blur(10px);border-bottom:1px solid transparent;transition:background var(--transicao),border-color var(--transicao),box-shadow var(--transicao)}
    .cabecalho.scrolled{background:rgba(246,242,235,0.94);border-bottom-color:var(--cor-cinza);box-shadow:var(--sombra)}
    .cabecalho__inner{display:flex;align-items:center;justify-content:space-between;gap:1rem;min-height:4.5rem}
    .logo{display:inline-flex;align-items:center;gap:0.6rem;text-decoration:none;color:var(--cor-marrom)}.logo__marca{height:2.5rem;width:auto}.logo__texto{display:flex;flex-direction:column;font-family:var(--fonte-titulo);font-size:var(--fs-md);font-weight:600;line-height:1.05}.logo__sub{font-family:var(--fonte-corpo);font-size:var(--fs-xs);font-weight:400;letter-spacing:0.14em;text-transform:uppercase;color:var(--cor-oliva)}
    .nav{display:flex;align-items:center;gap:clamp(1rem,2vw,2rem)}
    .nav__lista{display:flex;align-items:center;gap:clamp(0.9rem,1.6vw,1.8rem)}
    .nav__link{text-decoration:none;font-size:var(--fs-sm);color:var(--cor-marrom);padding:0.3rem 0;position:relative}
    .nav__toggle{display:none;background:none;border:0;padding:0.5rem;border-radius:var(--raio-sm)}
    .nav__toggle svg{width:28px;height:28px;stroke:var(--cor-marrom)}
    .btn{display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--fonte-corpo);font-size:var(--fs-sm);font-weight:700;letter-spacing:0.01em;text-decoration:none;padding:0.75rem 1.4rem;border-radius:999px;border:2px solid transparent;transition:background var(--transicao),color var(--transicao),border-color var(--transicao),transform var(--transicao)}
    .btn--primario{background:var(--cor-oliva);color:var(--cor-creme)}
    .link-texto{font-weight:700;text-decoration:none;color:var(--cor-oliva);border-bottom:2px solid currentColor;padding-bottom:2px}
    .hero{padding-block:clamp(3rem,2rem + 5vw,6rem);position:relative;overflow:hidden}
    .hero>.container{position:relative;z-index:1}
    .hero::before{content:"";position:absolute;z-index:0;right:-120px;top:50%;transform:translateY(-50%);width:clamp(280px,38vw,460px);aspect-ratio:1;border-radius:50%;background:radial-gradient(circle,rgba(167,174,140,0.35),rgba(167,174,140,0) 70%);pointer-events:none}
    .hero__grid{display:grid;grid-template-columns:1.1fr 0.9fr;gap:clamp(2rem,5vw,4rem);align-items:center}
    .hero__frase{font-family:var(--fonte-titulo);font-size:var(--fs-hero);line-height:1.12;font-weight:600;margin-bottom:1.5rem}
    .hero__nome{font-size:var(--fs-md);margin-bottom:0.25rem}.hero__nome strong{color:var(--cor-oliva)}
    .hero__sub{color:var(--marrom-suave);margin-bottom:1.25rem}.hero__apoio{margin-bottom:2rem}
    .hero__ctas{display:flex;flex-wrap:wrap;align-items:center;gap:1.25rem}
    .hero__foto{border-radius:var(--raio);box-shadow:var(--sombra);aspect-ratio:4/5;object-fit:cover;width:100%}
    @media (max-width:920px){.hero__grid{grid-template-columns:1fr}.hero__foto{max-width:420px}}
    @media (max-width:760px){.nav__toggle{display:inline-flex}.nav__lista{position:fixed;inset:4.5rem 0 auto 0;flex-direction:column;align-items:flex-start;gap:0;background:var(--cor-creme);border-bottom:var(--borda);box-shadow:var(--sombra);padding:0.5rem 1.5rem 1.5rem;transform:translateY(-120%);transition:transform 260ms ease}.nav[data-aberto="true"] .nav__lista{transform:translateY(0)}.nav__lista li{width:100%;border-bottom:var(--borda)}.nav__lista li:last-child{border-bottom:0}.nav__link{display:block;padding:0.9rem 0}.nav .btn{margin-top:1rem}}
  </style>
  <link rel="stylesheet" href="{{ root }}assets/css/styles.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ root }}assets/css/styles.css"></noscript>
  {% if jsonld %}{{ jsonld | safe }}{% endif %}
</head>

<body>
  <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>

  <header class="cabecalho" data-cabecalho>
    <div class="container cabecalho__inner">
      <a class="logo" href="{{ root }}index.html" aria-label="Giovanna Gimenez · Psicanálise Clínica">
        <img class="logo__marca" src="{{ root }}assets/logo/monograma.png" width="149" height="171" alt="">
        <span class="logo__texto">Giovanna Gimenez<span class="logo__sub">Psicanálise Clínica</span></span>
      </a>
      <nav class="nav" data-nav aria-label="Navegação principal">
        <button class="nav__toggle" data-nav-toggle aria-expanded="false" aria-controls="menu" aria-label="Abrir menu">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
        </button>
        <ul class="nav__lista" id="menu">
          <li><a class="nav__link" href="{{ root }}index.html#inicio">Início</a></li>
          <li><a class="nav__link" href="{{ root }}index.html#sobre">Sobre</a></li>
          <li><a class="nav__link" href="{{ root }}reflexoes/index.html">Reflexões</a></li>
          <li><a class="nav__link" href="{{ root }}index.html#contato">Contato</a></li>
          <li><a class="btn btn--primario" href="https://wa.me/5511999999999" target="_blank" rel="noopener">Agendar</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main id="conteudo">
{{ content | safe }}
  </main>

  <footer class="rodape">
    <div class="container">
      <p class="rodape__frase">A psicanálise não oferece respostas prontas. Ela abre espaço para que você se escute de verdade.</p>
      <p class="rodape__copy">© <span data-ano>2026</span> Giovanna Gimenez · Psicanálise Clínica.</p>
    </div>
  </footer>

  <script src="{{ root }}assets/js/main.js" defer></script>
</body>
</html>
